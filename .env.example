# Port the API server runs on
PORT=5000

# MongoDB connection string
# Local MongoDB:
MONGO_URI=mongodb+srv://<db_username>:6E4djlghmNIUPT3E@cluster0.egm0e9q.mongodb.net/?appName=Cluster0
# MongoDB Atlas (cloud) example:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nearbyhub

# JWT secret used to sign auth tokens - change this to a long random string
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend origin allowed to call this API (Vite dev server default)
CLIENT_URL=http://localhost:5173
